# ===== Omnisciência / Config =====

# LLM
# Provider via litellm: exemplos comuns: openai, azure, gemini, anthropic
OMNI_LLM_PROVIDER=
OMNI_LLM_MODEL=
OMNI_LLM_API_KEY=

# Exemplo (Gemini / Google AI Studio):
# OMNI_LLM_PROVIDER=gemini
# Dica: rode `python data/tmp/gemini_list_models.py` para ver os modelos disponíveis na sua chave.
OMNI_LLM_MODEL=gemini/gemini-flash-lite-latest
# OMNI_LLM_API_KEY=... (NÃO cole em commits)

# Exemplo (Groq):
# OMNI_LLM_PROVIDER=groq
# OMNI_LLM_MODEL=groq/llama-3.3-70b-versatile
# OMNI_LLM_API_KEY=... (NÃO cole em commits)

# Router mode: llm | heuristic
# Para habilitar o roteamento via LLM: defina OMNI_ROUTER_MODE=llm e configure OMNI_LLM_*.
OMNI_ROUTER_MODE=heuristic

# STT mode: text | whisper_openai | vosk
OMNI_STT_MODE=text

# STT (Whisper API)
# Chave: nunca commitar. Use .env (ignorado) ou variável do sistema.
OMNI_STT_OPENAI_API_KEY=
OMNI_STT_OPENAI_MODEL=whisper-1

# Gravação (push-to-talk simplificado)
OMNI_STT_RECORD_SECONDS=6
OMNI_STT_SAMPLE_RATE=16000

# Se o microfone padrão não funcionar, você pode fixar o índice do dispositivo:
# Dica: rode `python -c "import sounddevice as sd; print(sd.query_devices())"`
OMNI_AUDIO_INPUT_DEVICE=

# Se o microfone estiver muito baixo (Vosk não reconhece), aumente o ganho:
# Exemplos: 5, 10, 20
OMNI_AUDIO_INPUT_GAIN=

# Wake word (palavra de ativação)
# Quando ligado e estiver em modo voz, o assistente só atende quando você chamar.
# Exemplos: "void abre o chrome", "ei void", "olá void".
OMNI_WAKE_WORD_ENABLED=false
OMNI_WAKE_WORD=void
# prefix | anywhere | smart
# - prefix: atende quando "void" vem no comeco (ex: "ei void ...")
# - anywhere: atende se "void" aparecer em qualquer parte da frase
# - smart: como anywhere, mas tenta evitar falsos positivos quando voce estiver falando de programacao/codigo
OMNI_WAKE_WORD_MODE=prefix
OMNI_WAKE_WORD_ACK=true
OMNI_WAKE_WORD_ACK_TEXT=Sim?

# STT offline (GRÁTIS) via Vosk:
# 1) `pip install -e .[voice]` (já inclui `vosk`)
# 2) Baixe um modelo do Vosk (pt-BR) e descompacte em uma pasta
# 3) Aponte a pasta aqui e use OMNI_STT_MODE=vosk
OMNI_STT_VOSK_MODEL_DIR=

# TTS mode: none | pyttsx3
# Para resposta falada (offline no Windows):
# 1) Instale deps: `pip install -e .[voice]` (ou `pip install pyttsx3`)
# 2) Ative: OMNI_TTS_MODE=pyttsx3
OMNI_TTS_MODE=none

# Web (Playwright)
# true = headless (recomendado para automação), false = navegador visível
OMNI_WEB_HEADLESS=true

# Se true, quando o usuário/LLM fornecer "example.com" sem esquema,
# o core pode assumir "https://example.com" durante a normalização.
# Default seguro: false (sem esquema => bloqueia e pede URL completa).
OMNI_WEB_ASSUME_HTTPS=false

# OCR (Tesseract)
# Se o tesseract.exe não estiver no PATH, aponte o caminho completo aqui.
# Ex (Windows): C:\\Program Files\\Tesseract-OCR\\tesseract.exe
OMNI_TESSERACT_CMD=

# Apps allowlisted (Windows)
# Você pode deixar a allowlist enorme via um JSON gerado automaticamente:
# - use o comando "gerar allowlist de apps" no agente (gera data/open_apps.generated.json)
# - aponte aqui:
OMNI_OPEN_APPS_FILE=data/open_apps.generated.json
# Alternativa: JSON inline (app -> target)
OMNI_OPEN_APPS_JSON=

# Segurança
# Quando true, qualquer ação CRITICAL exige aprovação humana.
OMNI_HITL_ENABLED=true

# Exigir aprovação a partir de qual risco:
# LOW | MEDIUM | HIGH | CRITICAL
# Observação: se você não definir esta variável, o default é HIGH (mais seguro).
# Se quiser menos prompts, você pode colocar CRITICAL.
OMNI_HITL_MIN_RISK=HIGH

# Quando true, a confirmação exige um token (ex: "YES A1B2") para evitar aprovações acidentais.
OMNI_HITL_REQUIRE_TOKEN=false

# Omega (confiabilidade)
# Ative para deixar o agente mais resiliente (retries em tools seguras).
OMNI_OMEGA=false

# Número máximo de tentativas por tool (quando OMNI_OMEGA=true)
OMNI_RETRY_MAX=3

# Backoff entre tentativas (segundos)
OMNI_RETRY_BACKOFF_S=0.35

# Retentar tools com side-effect (cliques/digitação/exec) NÃO é recomendado.
OMNI_RETRY_SIDE_EFFECTS=false

# Log
OMNI_LOG_LEVEL=INFO

# ===== Jarvis / Extensibilidade (opt-in) =====
# Tudo aqui é DESLIGADO por padrão.
# Recomendações de segurança:
# - Mantenha OMNI_HITL_ENABLED=true
# - Considere OMNI_HITL_REQUIRE_TOKEN=true ao habilitar self-coding

# Carrega tools de `omniscia/tools/custom/*.py` (ver `omniscia/tools/custom/README` no docstring do pacote)
OMNI_CUSTOM_TOOLS_ENABLED=false

# Permite que o agente escreva scripts temporários em `scratch/` e rode via `dev.run_python`.
# ATENÇÃO: habilita auto-código. Use com HITL forte.
OMNI_SELF_CODING_ENABLED=false

# Memória vetorial (ChromaDB) para busca semântica / RAG
OMNI_VECTOR_MEMORY_ENABLED=false
# Se true, tenta indexar automaticamente eventos recentes ao iniciar.
OMNI_VECTOR_MEMORY_AUTO_INDEX=false

# Hotkey global (Ctrl+Space): no próximo comando, captura contexto de tela (screenshot + OCR)
# Requer extra: `pip install -e .[hotkeys]`
OMNI_HOTKEY_SCREEN_ENABLED=false

# Proatividade (scheduler): alertas sobre CPU/RAM (apenas alerta; não mata processos automaticamente)
# Requer extra: `pip install -e .[proactive]`
OMNI_PROACTIVE_ENABLED=false
OMNI_PROACTIVE_INTERVAL_S=300
OMNI_PROACTIVE_CPU_THRESHOLD=95
OMNI_PROACTIVE_RAM_THRESHOLD=95
