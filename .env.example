# ===== Omnisciência / Config =====

# LLM
# Provider via litellm: exemplos comuns: openai, azure, gemini, anthropic
OMNI_LLM_PROVIDER=
OMNI_LLM_MODEL=
OMNI_LLM_API_KEY=

# Router mode: llm | heuristic
# Para habilitar o roteamento via LLM: defina OMNI_ROUTER_MODE=llm e configure OMNI_LLM_*.
OMNI_ROUTER_MODE=heuristic

# STT mode: text | whisper_openai
OMNI_STT_MODE=text

# STT (Whisper API)
# Chave: nunca commitar. Use .env (ignorado) ou variável do sistema.
OMNI_STT_OPENAI_API_KEY=
OMNI_STT_OPENAI_MODEL=whisper-1

# Gravação (push-to-talk simplificado)
OMNI_STT_RECORD_SECONDS=6
OMNI_STT_SAMPLE_RATE=16000

# TTS mode: none | pyttsx3
OMNI_TTS_MODE=none

# Web (Playwright)
# true = headless (recomendado para automação), false = navegador visível
OMNI_WEB_HEADLESS=true

# Se true, quando o usuário/LLM fornecer "example.com" sem esquema,
# o core pode assumir "https://example.com" durante a normalização.
# Default seguro: false (sem esquema => bloqueia e pede URL completa).
OMNI_WEB_ASSUME_HTTPS=false

# OCR (Tesseract)
# Se o tesseract.exe não estiver no PATH, aponte o caminho completo aqui.
# Ex (Windows): C:\\Program Files\\Tesseract-OCR\\tesseract.exe
OMNI_TESSERACT_CMD=

# Segurança
# Quando true, qualquer ação CRITICAL exige aprovação humana.
OMNI_HITL_ENABLED=true

# Exigir aprovação a partir de qual risco:
# LOW | MEDIUM | HIGH | CRITICAL
# Observação: se OMNI_ROUTER_MODE=llm e você não definir esta variável,
# o default passa a ser HIGH (mais seguro).
OMNI_HITL_MIN_RISK=CRITICAL

# Quando true, a confirmação exige um token (ex: "YES A1B2") para evitar aprovações acidentais.
OMNI_HITL_REQUIRE_TOKEN=false

# Log
OMNI_LOG_LEVEL=INFO
